{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/tauri_capabilities_schema.json",
  "identifier": "default",
  "description": "Default capabilities for Steam Box",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-start-dragging",
    "core:window:allow-set-size",
    "core:window:allow-center",
    "core:window:allow-show",
    "core:window:allow-hide",
    "shell:allow-open"
  ]
}
